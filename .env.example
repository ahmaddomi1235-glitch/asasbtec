# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for أساس مهني
#
# HOW TO USE:
#   1. Copy this file to .env.local for local development
#   2. Set these in Vercel Dashboard → Project → Settings → Environment Variables
#      for production deployments
#
# IMPORTANT: VITE_ prefix is required — Vite only exposes variables with this
#            prefix to the client bundle. Other variables stay server-side only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site URL (used for canonical, og:url, og:image, twitter:image) ──────────
# Set to your custom domain (with https, no trailing slash).
# Example: https://www.asasmehani.com
# Fallback used when not set: empty string (canonical tag will be empty — ok for dev)
VITE_SITE_URL=https://asasbtec.vercel.app

# ── Base path (used for assets, icons, manifest) ────────────────────────────
# Leave as '/' for Vercel root deployments (the default).
# Only change if deploying to a subpath (e.g. GitHub Pages /asasbtec/).
VITE_BASE_PATH=/
