# Default environment variables — committed to git, safe for public values only.
# Override in Vercel Dashboard → Settings → Environment Variables.
#
# IMPORTANT: After adding your custom domain in Vercel, update VITE_SITE_URL to:
#   https://www.YOUR_DOMAIN.com   (or apex if that is your primary)
# Then trigger a new deploy so the canonical/og:url tags reflect the new domain.

VITE_SITE_URL=https://asasbtec.vercel.app
VITE_BASE_PATH=/
